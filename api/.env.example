PORT=3001

R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY=your_access_key
R2_SECRET_KEY=your_secret_key
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_DOMAIN=your_public_domain

DATABASE_PATH=./database.sqlite
SPACETIME_DB_IDENTITY_URL=your_identity_url

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=your_google_callback_url

# --- Discord OAuth ---
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_CALLBACK_URL=your_discord_callback_url

REDIRECT_URI=your_redirect_uri

# SpacetimeDB Configuration
SPACETIME_DB_NAME=eventdekk
SPACETIME_DB_URI=ws://localhost:3000
SPACETIME_AUTH_TOKEN=your_admin_token_here

# Infinite Flight API Configuration
IF_API_URL=https://api.infiniteflight.com/public/v2
IF_API_KEY=your_if_api_key_here

# Flight Update Scheduler Configuration
FLIGHT_UPDATE_INTERVAL_MS=30000
